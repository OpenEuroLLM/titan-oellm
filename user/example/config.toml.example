# Local development / debug configuration template
#
# SETUP INSTRUCTIONS:
# 1. Copy to user/configs/debug.toml (the user/ folder is gitignored)
# 2. Update paths for your environment
# 3. Run: CONFIG=user/configs/debug.toml bash submit_job.sh --local
#
# This config is for local testing, debugging, and interactive node development.
# Use cluster SLURM scripts with different configs for production training.

[job]
description = "Local debug run"
dump_folder = "experiments/local_test"
custom_config_module = "titan_oellm.configs.sci_job_config"

[model]
name = "qwen3_custom"
flavor = "debugmodel"
# Override with your tokenizer path
tokenizer_path = "/path/to/your/tokenizer/neox"

[data]
# Local dataset path (use small subset for testing)
data_prefix = "/path/to/your/dataset/train_merged"
chunks_dir = "/path/to/your/dataset/train_chunks"
dataloader = "MMapDataset"
local_batch_size = 2
seq_len = 512

[training]
steps = 100
local_batch_size = 2
mixed_precision_param = "bfloat16"

[optimizer]
name = "AdamW"
lr = 2e-3

[lr_scheduler]
scheduler_type = "cosine"
warmup_steps = 0
cooldown_steps = 0

[metrics]
log_freq = 50
enable_tensorboard = true
save_tb_folder = "tb"

[checkpoint]
enable = false
