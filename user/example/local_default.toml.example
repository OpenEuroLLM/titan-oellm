# Local development configuration template
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to user/local_default.toml (the user/ folder is gitignored)
# 2. Replace all paths with your local development paths
# 3. Adjust training parameters for local testing
#
# This config is designed for local development and testing.
# Use cluster-specific SLURM scripts for actual training.

[job]
description = "Local development run"
custom_config_module = "titan_oellm.configs.sci_job_config"

[data]
# Local dataset path (use small subset for testing)
tokenizer_path = "/path/to/your/tokenizer/neox"
data_prefix = "/path/to/your/dataset/train_merged"
local_batch_size = 2
seq_len = 1024

[training]
steps = 100
local_batch_size = 2
compile = false

[model]
name = "gpt_plus"
vocab_size = 50432
dim = 512
n_layers = 8
n_heads = 8

# Custom config module for titan-oellm
custom_import = "titan_oellm.models"

[optimizer]
name = "AdamW"
lr = 1e-4

[lr_scheduler]
scheduler_type = "wsd"
warmup_steps = 10
decay_ratio = 0.1

[metrics]
enable_tensorboard = true
log_freq = 10

[checkpoint]
enable_checkpoint = false