Bootstrap: docker
From: nvcr.io/nvidia/pytorch:25.10-py3


%arguments
    PYTHON_VERSION=3.12.3
    FLASH_ATTN_VERSION=v2.8.3
    BUILD_FA3=false

%files
    setup.py /opt/titan-oellm/
    titan_oellm /opt/titan-oellm/
    torchtitan /opt/titan-oellm/
    torchtitan/.ci/docker/requirements.txt /opt/
    torchtitan/.ci/docker/requirements-dev.txt /opt/
    torchtitan/.ci/docker/requirements-flux.txt /opt/


%environment
    export USER=torchtitan
    export HOME=/workspace
    export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:/usr/lib/aarch64-linux-gnu:/opt/hpcx/nccl_rdma_sharp_plugin/lib:/opt/hpcx/nccl_rdma_sharp_plugin/lib
    export MAX_JOBS=4


%post

    pip install --upgrade pip setuptools wheel cmake ninja packaging

    # Create lib -> lib.real symlink for Triton 3.4+ compatibility
    # NVIDIA containers store CUDA compat libraries in lib.real/ but Triton expects lib/
    # This is required for PyTorch 2.9+ with torch.compile
    if [ -d /usr/local/cuda/compat/lib.real ] && [ ! -e /usr/local/cuda/compat/lib ]; then
        ln -s lib.real /usr/local/cuda/compat/lib
        echo "Created symlink: /usr/local/cuda/compat/lib -> lib.real"
    fi

    # Install PyTorch nightly 2.10.0.dev20251116 to get latest torch.compile fixes
    # Using CUDA 13.0 index (cu130) to match container's CUDA 13.0
    # Version 20251028 is the latest with both aarch64 (ARM) and x86_64 (AMD) support
    echo "Installing PyTorch nightly 2.10.0.dev20251116+cu130 with CUDA 13.0..."
    pip install --no-cache-dir --pre torch==2.10.0.dev20251116 torchvision torchaudio --index-url https://download.pytorch.org/whl/nightly/cu130

    # Verify PyTorch version
    python3 -c "import torch; print(f'PyTorch version: {torch.__version__}'); print(f'CUDA available: {torch.cuda.is_available()}')"

    pip install --no-cache-dir array-record pytest black flake8 mypy etcd3 python-etcd torchelastic

    grep -v "^torch" /opt/requirements.txt > /tmp/requirements-filtered.txt || cp /opt/requirements.txt /tmp/requirements-filtered.txt
    pip install --no-cache-dir -r /tmp/requirements-filtered.txt
    pip install --no-cache-dir -r /opt/requirements-dev.txt
    pip install --no-cache-dir -r /opt/requirements-flux.txt

    # Clone Flash Attention repo at pinned version (single clone for both FA2 and FA3)
    # This ensures version consistency between FA2 and FA3
    echo "Cloning Flash Attention v2.8.3..."
    git clone --depth 1 --branch v2.8.3 https://github.com/Dao-AILab/flash-attention.git /tmp/flash-attention
    cd /tmp/flash-attention

    # Build Flash Attention 2 from repo root (works on Ampere SM80+ and Ada SM89)
    # MAX_JOBS limits parallel compilation to avoid OOM during build
    echo "Building Flash Attention 2 from source..."
    MAX_JOBS=4 pip install . --no-build-isolation

    # Verify Flash Attention 2 installation
    python3 -c "from flash_attn import flash_attn_varlen_func; print('Flash Attention 2 installed successfully')" || echo "Warning: Flash Attention 2 not available"

    # Build Flash Attention 3 from hopper/ subdirectory (Hopper SM90+ only)
    # Requires: H100/H800 GPU, CUDA >= 12.3 (12.8 recommended)
    # Only build if BUILD_FA3=true (set via --build-arg BUILD_FA3=true)
    if [ "${BUILD_FA3}" = "true" ]; then
        echo "Building Flash Attention 3 from hopper/ (Hopper-only)..."
        cd /tmp/flash-attention/hopper
        python setup.py install || echo "FA3 build failed (expected on non-Hopper systems)"

        # Verify Flash Attention 3 (Hopper) if available
        # Package is named "flash_attn_3" when built from hopper/ subdirectory
        python3 -c "from flash_attn_3.flash_attn_interface import flash_attn_varlen_func; print('Flash Attention 3 (Hopper) installed successfully')" 2>/dev/null || echo "FA3 not available (Hopper-only)"
    else
        echo "Skipping Flash Attention 3 build (BUILD_FA3=${BUILD_FA3})"
    fi

    # Cleanup
    cd /
    rm -rf /tmp/flash-attention

    cd /opt/titan-oellmd/torchtitan
    pip install -e .

    cd /opt/titan-oellm
    pip install -e .

    mkdir -p /workspace
    chmod 777 /workspace

    mkdir -p /home/torchtitan
    chmod 777 /home/torchtitan



%labels
    Author Joerg Franke
    Version 0.2.0
    Base nvcr.io/nvidia/pytorch:25.10-py3
    PyTorch PyTorch nightly 2.9.x from https://download.pytorch.org/whl/nightly/cu130
    Description Titan-OELLM container for TorchTitan 0.2.0 with PyTorch nightly (CUDA 13.0) for torch.compile fixes









